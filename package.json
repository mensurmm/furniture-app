{
  "name": "furniture-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "extract-en": "formatjs extract 'src/**/*.{ts,tsx}' --out-file messages/en.json --format flat",
    "translate-am": "json-translator --mode file --source en --target am --input messages/en.json --output messages/am.json",
    "sync-i18n": "npm run extract-en && npm run translate-am"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.3",
    "next": "16.2.10",
    "next-intl": "^4.13.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@formatjs/cli": "^6.16.14",
    "@samchon/json-translator": "^2.1.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
